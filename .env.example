# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/interview_review

# Redis
# NOTE: Default port 6379 may conflict with Windows Hyper-V excluded port range.
# If Redis fails to start, check: netsh interface ipv4 show excludedportrange protocol=tcp
# Use a port outside the excluded range (e.g., 6500).
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=7d

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user
SMTP_PASS=pass
SMTP_FROM=noreply@example.com

# LLM (OpenAI-compatible — works with OpenAI, Groq, Together, Ollama, LM Studio, etc.)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o

# App
APP_PORT=4000
APP_URL=http://localhost:4000
WEB_URL=http://localhost:3000
NODE_ENV=development

# Docker Compose Production
DB_NAME=interview_review
DB_USER=user
DB_PASS=change-me-to-a-strong-password
APP_EXTERNAL_PORT=80
